/**
 * Implements hook_page_attachments().
 */
function dhcr_backend_page_attachments(array &$attachments): void {
  $route_name = \Drupal::routeMatch()->getRouteName() ?? '';

  if (
    str_starts_with($route_name, 'dhcr_backend.') ||
    str_starts_with($route_name, 'entity.dhcr_')
  ) {
    $attachments['#attached']['library'][] = 'dhcr_backend/admin_base';
    $attachments['#attached']['library'][] = 'dhcr_backend/fontawesome_free';
    $attachments['#attached']['library'][] = 'dhcr_backend/admin_table_search';
  }
}
